NODE_ENV=development
PORT=4000

# MySQL (use strong credentials in production)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=kesher
DB_PASSWORD=kesher_dev_password
DB_NAME=kesher

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=30d

# CORS (comma-separated origins, or * for dev)
CORS_ORIGIN=http://localhost:5173

# Cloudinary (profile photos) — get from Cloudinary dashboard
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@cloud_name
CLOUDINARY_URL=
