{
  "name": "kesher-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Kesher matchmaking API (Node.js + MySQL)",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js --status",
    "seed:approval-queue": "node scripts/seedApprovalQueue.js",
    "seed:approval-queue:reset": "node scripts/seedApprovalQueue.js --reset",
    "seed:discovery-users": "node scripts/seedDiscoveryUsers.js",
    "seed:discovery-users:reset": "node scripts/seedDiscoveryUsers.js --reset"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
